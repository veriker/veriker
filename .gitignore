# TUF root PRIVATE key halves — generated by release/tuf_root_bootstrap.py.
# Per Pass-1 tightening item 7 + c18-CKP-B audit dimension 1.e: PRIVATE
# key material MUST NEVER be committed. The substrate ships PUBLIC keys
# only (in audit_bundle/extensions/_tuf_root/root.json). The ceremony
# generates private halves here for LOCAL signing; production ceremony
# replaces these with hardware-rooted keys per _tuf_root/README.md.
release/.tuf-root-privkeys-LOCAL/
release/.tuf-root-privkeys/

# Release artifacts (generated at release-tag-cut by .github/workflows/release.yml)
release/dist/
release/mirror_log/

# Python bytecode (closes verifier-self-pollution per memory
# the internal design notes — cli/verify.py
# also sets sys.dont_write_bytecode = True; this is the belt-and-
# suspenders rail at the repo level)
__pycache__/
*.pyc
*.pyo

# Editor + venv noise
.venv/
*.egg-info/
.pytest_cache/
# Hypothesis property-test example database (per-machine cache)
.hypothesis/

# Generated coverage rollup (produced by scripts/version_pass_rate.py)
coverage/version_pass_rate.json
# Ruff cache (lint state; per-machine)
.ruff_cache/

# Verify-time bundle event log (C16 Fork A divergence records, C18 tripwire
# events). Emitted into bundle dirs at verify time — incl. soak fixture dirs
# during soak_verify runs. NOT part of manifest.files (integrity-safe to
# append); never committed.
events.jsonl

# agent-honesty-gate transient + internal baseline artifacts
/report.xml
